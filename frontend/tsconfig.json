{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2015",
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./js",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["js/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
